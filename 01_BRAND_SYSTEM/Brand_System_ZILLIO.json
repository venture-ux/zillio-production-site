  "aesthetic_rules": {
    "whitespace": "generous (1.2-1.5x standard), data-dense tables (0.8x)",
    "contrast": "WCAG AAA (7:1 minimum)",
    "typography": "institutional, data-first, 16+ reading level",
    "animations": "understated, Bloomberg-style, cubic-bezier only, 0.2s-0.5s",
    "imagery": "data visualizations, charts, minimal photography",
    "data_density": "3-5 metrics per viewport",
    "reading_time": "5-10 min per page (long-form content)",
    "credibility": "cited sources on every claim",
    "authority": "McKinsey-quality production",

    "approved_patterns": [
      "Fade-in on scroll (IntersectionObserver)",
      "Subtle hover states (5% brightness increase)",
      "Card elevation on hover (shadow transition)",
      "Link underline fade-in",
      "Data table row highlight",
      "Smooth page transitions"
    ],

    "banned_elements": [
      "Exclamation points (!)",
      "Emoji",
      "Marketing buzzwords: unlock, supercharge, game-changing, revolutionary, transform, next-level, world-class, cutting-edge, innovative, seamless, best-in-class, turnkey, one-stop-shop",
      "Promotional language: limited time, act now, don't miss out, exclusive deal, only X spots left",
      "Bouncy animations: elastic, spring, bounce",
      "Rainbow gradients",
      "Vibrant colors (>40% saturation)",
      "Generic stock photos (people smiling at camera)",
      "Clip art or illustrations (use data visualizations)",
      "Infinite animation loops (except loading)",
      "Aggressive transitions (>0.5s)",
      "Large scale changes (>1.05)"
    ]
  },

  "content_standards": {
    "reading_level": "16+ (Graduate/Professional: MBA, CFA level)",
    "tone": "institutional, authoritative, educational",
    "style": "clear, concise, data-heavy",
    "pov": "third-person or 'we' addressing 'you'",
    "sentence_structure": "mix of short (clarity) and complex (sophistication)",
    "technical_terminology": "assume audience knows: IRR, LTV, NAV, AUM, YoY, QoQ, CAGR",
    "data_requirements": [
      "Always cite sources: (Source: UBS Global Wealth Report 2026)",
      "Always show methodology: We rate markets using 7 criteria...",
      "Always quantify: 8-12% rental yield (not 'high returns')",
      "Always benchmark: vs. peer average of 55% (not 'great allocation')"
    ]
  },

  "approved_language_patterns": {
    "instead_of_marketing": {
      "unlock_potential": "Systematic portfolio analysis against 100,000+ peer benchmarks",
      "game_changing": "Dubai real estate: 12-17% IRR (historical, 2020-2025)",
      "revolutionary_platform": "AI-powered wealth audit engine analyzing $50B+ in portfolios",
      "transform_wealth": "Reallocate 20-25% to international assets (peer average: 45%)",
      "world_class_experts": "1,000+ certified advisors (average: 15 years experience, 4.7/5 rating)",
      "cutting_edge": "Real-time portfolio monitoring with automated risk alerts"
    }
  },


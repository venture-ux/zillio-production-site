  "aesthetic_rules": {
    "whitespace": "generous (1.5-2x standard spacing)",
    "contrast": "high (WCAG AAA minimum, 7:1 ratio)",
    "typography": "stark, institutional, university-grade",
    "animations": "understated, cubic-bezier easing only",
    "imagery": "high-resolution (4K+), muted (20-40% saturation), professional composition",
    "color_saturation": "20-40% maximum (muted palette)",
    "grid_systems": "12-column, base-8 spacing",
    "reading_level": "14+ (university graduate)",

    "approved_patterns": [
      "Fade-up reveals on scroll",
      "Subtle hover states (5% brightness/scale change)",
      "Smooth page transitions",
      "Parallax effects (<20px movement)",
      "Staggered grid animations (0.1s delays)"
    ],

    "banned_elements": [
      "Exclamation points (!)",
      "Marketing buzzwords (unlock, supercharge, journey, innovative, cutting-edge, next-level, game-changing, revolutionary, transform, disruptive, empower, seamless, world-class, best-in-class, turnkey, one-stop-shop)",
      "Bouncy animations (elastic, spring, bounce easing)",
      "Cheap gradients (rainbow, vibrant multi-color)",
      "Overly colorful palettes (>60% saturation)",
      "Generic stock photos (people smiling at camera, business handshakes)",
      "Clip art or illustration style",
      "Linear easing on animations",
      "Infinite animation loops (except loading states)"
    ]
  },

  "accessibility": {
    "wcag_level": "AAA",
    "contrast_ratio": "7:1 minimum",
    "focus_indicators": "2px solid outline, 4px offset",
    "keyboard_navigation": "required for all interactive elements",
    "semantic_html": "required (section, article, nav, header, footer)",
    "aria_labels": "required for all non-text interactive elements",
    "alt_text": "required for all images, detailed descriptions"
  },

  "performance": {
    "image_optimization": "WebP with JPEG fallback",
    "lazy_loading": "below-fold images only",
    "code_splitting": "dynamic imports for heavy components",
    "css_animations": "GPU-accelerated properties only (transform, opacity)",
    "javascript_budget": "minimize JS, prefer CSS animations",
    "font_loading": "font-display: swap",
    "critical_css": "inline critical path CSS"
  },

